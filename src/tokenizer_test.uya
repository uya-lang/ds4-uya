use ds4.gguf.GgufString;
use ds4.tokenizer.TokenizerByteBuffer;
use ds4.tokenizer.TokenizerTokenVec;
use ds4.tokenizer.TokenizerVocab;
use ds4.tokenizer.tokenizer_byte_buffer_deinit;
use ds4.tokenizer.tokenizer_byte_buffer_init;
use ds4.tokenizer.tokenizer_decode_tokens;
use ds4.tokenizer.tokenizer_encode_text;
use ds4.tokenizer.tokenizer_piece_from_tokens_offset;
use ds4.tokenizer.tokenizer_token_vec_deinit;
use ds4.tokenizer.tokenizer_token_vec_init;
use ds4.tokenizer.tokenizer_vocab_deinit;
use ds4.tokenizer.tokenizer_vocab_init;
use ds4.tokenizer.tokenizer_vocab_init_manual;
use ds4.tokenizer.tokenizer_vocab_set_merge;
use ds4.tokenizer.tokenizer_vocab_set_token;
use libc.FILE;
use libc.fclose;
use libc.fopen;
use libc.fwrite;
use libc.remove;
use std.testing.assert_eq_i32;

fn write_u64_le(buf: &byte, offset: usize, value: u64) void {
    buf[offset + 0] = value as byte;
    buf[offset + 1] = (value >> 8) as byte;
    buf[offset + 2] = (value >> 16) as byte;
    buf[offset + 3] = (value >> 24) as byte;
    buf[offset + 4] = (value >> 32) as byte;
    buf[offset + 5] = (value >> 40) as byte;
    buf[offset + 6] = (value >> 48) as byte;
    buf[offset + 7] = (value >> 56) as byte;
}

fn write_token_fixture(path: &const byte) bool {
    var data: [byte: 32] = [];

    write_u64_le(&data[0], 0, 1);
    data[8] = 97;

    write_u64_le(&data[0], 9, 2);
    data[17] = 98;
    data[18] = 99;

    write_u64_le(&data[0], 19, 5);
    data[27] = 104;
    data[28] = 101;
    data[29] = 108;
    data[30] = 108;
    data[31] = 111;

    const fp: &FILE = fopen(path, "wb\0" as &const byte);
    if fp == null {
        return false;
    }
    const wrote: usize = fwrite(&data[0], 1 as usize, 32 as usize, fp);
    _ = fclose(fp);
    return wrote == 32;
}

test "tokenizer_piece_from_tokens_offset" {
    const path: &const byte = "/tmp/ds4-uya-tokenizer-piece-test.bin\0" as &const byte;
    _ = remove(path);
    try assert_eq_i32(write_token_fixture(path) as i32, 1);

    var piece: GgufString = GgufString{ len: 0, shown: 0, data: [] };
    const rc: i32 = tokenizer_piece_from_tokens_offset(path, 32, 0, 3, 1, &piece);
    try assert_eq_i32(rc, 0);
    try assert_eq_i32(piece.len as i32, 2);
    try assert_eq_i32(piece.data[0] as i32, 98);
    try assert_eq_i32(piece.data[1] as i32, 99);

    const out_of_range: i32 = tokenizer_piece_from_tokens_offset(path, 32, 0, 3, 3, &piece);
    try assert_eq_i32(out_of_range, 7);
    _ = remove(path);
}

test "tokenizer_encode_decode_roundtrip_with_control" {
    var vocab: TokenizerVocab = tokenizer_vocab_init();
    try assert_eq_i32(tokenizer_vocab_init_manual(&vocab, 6, 1) as i32, 1);
    try assert_eq_i32(tokenizer_vocab_set_token(&vocab, 0, "b\0" as &const byte, 1) as i32, 1);
    try assert_eq_i32(tokenizer_vocab_set_token(&vocab, 1, "c\0" as &const byte, 1) as i32, 1);
    try assert_eq_i32(tokenizer_vocab_set_token(&vocab, 2, "bc\0" as &const byte, 1) as i32, 1);
    try assert_eq_i32(tokenizer_vocab_set_token(&vocab, 3, "a\0" as &const byte, 1) as i32, 1);
    try assert_eq_i32(tokenizer_vocab_set_token(&vocab, 4, "x\0" as &const byte, 1) as i32, 1);
    try assert_eq_i32(tokenizer_vocab_set_token(&vocab, 5, "<think>\0" as &const byte, 3) as i32, 1);
    try assert_eq_i32(tokenizer_vocab_set_merge(&vocab, 0, "b c\0" as &const byte) as i32, 1);

    var tokens: TokenizerTokenVec = tokenizer_token_vec_init();
    const encode_rc: i32 = tokenizer_encode_text(&vocab, "a<think>bc\0" as &const byte, &tokens, true, false, false);
    try assert_eq_i32(encode_rc, 0);
    try assert_eq_i32(tokens.len as i32, 3);
    try assert_eq_i32(tokens.data[0], 3);
    try assert_eq_i32(tokens.data[1], 5);
    try assert_eq_i32(tokens.data[2], 2);

    var decoded: TokenizerByteBuffer = tokenizer_byte_buffer_init();
    const decode_rc: i32 = tokenizer_decode_tokens(&vocab, &tokens, &decoded);
    try assert_eq_i32(decode_rc, 0);
    try assert_eq_i32(decoded.len as i32, 10);
    try assert_eq_i32(decoded.data[0] as i32, 97);
    try assert_eq_i32(decoded.data[1] as i32, 60);
    try assert_eq_i32(decoded.data[7] as i32, 62);
    try assert_eq_i32(decoded.data[8] as i32, 98);
    try assert_eq_i32(decoded.data[9] as i32, 99);

    tokenizer_byte_buffer_deinit(&decoded);
    tokenizer_token_vec_deinit(&tokens);
    tokenizer_vocab_deinit(&vocab);
}

test "tokenizer_adds_bos_eos_and_unknown_special" {
    var vocab: TokenizerVocab = tokenizer_vocab_init();
    try assert_eq_i32(tokenizer_vocab_init_manual(&vocab, 6, 1) as i32, 1);
    try assert_eq_i32(tokenizer_vocab_set_token(&vocab, 0, "b\0" as &const byte, 1) as i32, 1);
    try assert_eq_i32(tokenizer_vocab_set_token(&vocab, 1, "c\0" as &const byte, 1) as i32, 1);
    try assert_eq_i32(tokenizer_vocab_set_token(&vocab, 2, "bc\0" as &const byte, 1) as i32, 1);
    try assert_eq_i32(tokenizer_vocab_set_token(&vocab, 3, "<unk>\0" as &const byte, 2) as i32, 1);
    try assert_eq_i32(tokenizer_vocab_set_token(&vocab, 4, "<bos>\0" as &const byte, 3) as i32, 1);
    try assert_eq_i32(tokenizer_vocab_set_token(&vocab, 5, "<eos>\0" as &const byte, 3) as i32, 1);
    try assert_eq_i32(tokenizer_vocab_set_merge(&vocab, 0, "b c\0" as &const byte) as i32, 1);
    vocab.bos_id = 4;
    vocab.eos_id = 5;
    vocab.unk_id = 3;

    var tokens: TokenizerTokenVec = tokenizer_token_vec_init();
    const encode_rc: i32 = tokenizer_encode_text(&vocab, "<unk>bc\0" as &const byte, &tokens, true, true, true);
    try assert_eq_i32(encode_rc, 0);
    try assert_eq_i32(tokens.len as i32, 4);
    try assert_eq_i32(tokens.data[0], 4);
    try assert_eq_i32(tokens.data[1], 3);
    try assert_eq_i32(tokens.data[2], 2);
    try assert_eq_i32(tokens.data[3], 5);

    tokenizer_token_vec_deinit(&tokens);
    tokenizer_vocab_deinit(&vocab);
}
