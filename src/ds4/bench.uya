use ds4.kernels.kernels_dense_matvec_f32;
use ds4.kernels.kernels_q4_k_dot_f32;
use ds4.kernels.kernels_q8_0_dot_f32;
use libc.CLOCKS_PER_SEC;
use libc.clock;
use libc.printf;

export struct BenchResult {
    prompt_tokens: u64,
    decode_tokens: u64,
    prompt_seconds: f32,
    decode_seconds: f32,
    prompt_tokens_per_sec: f32,
    decode_tokens_per_sec: f32,
    checksum: f32,
}

fn bench_elapsed_seconds(start: u64, finish: u64) f32 {
    var ticks: u64 = 1;
    if finish > start {
        ticks = finish - start;
    }
    return (ticks as f32) / (CLOCKS_PER_SEC as f32);
}

fn bench_init(matrix: &f32, x: &f32, q8: &byte, q4: &byte) void {
    var i: u64 = 0;
    while i < 1024 {
        matrix[i as usize] = (((i % 17) as f32) - 8.0f32) * 0.01f32;
        i = i + 1;
    }
    i = 0;
    while i < 64 {
        x[i as usize] = ((i % 11) as f32) * 0.02f32 + 0.1f32;
        i = i + 1;
    }
    i = 0;
    while i < 34 {
        q8[i as usize] = 0;
        i = i + 1;
    }
    q8[0] = 0;
    q8[1] = 0x3c;
    i = 0;
    while i < 32 {
        q8[(2 + i) as usize] = ((i % (7 as u64)) + 1) as byte;
        i = i + 1;
    }
    i = 0;
    while i < 144 {
        q4[i as usize] = 0;
        i = i + 1;
    }
    q4[0] = 0;
    q4[1] = 0x3c;
    q4[4] = 1;
    i = 0;
    while i < 32 {
        q4[(16 + i) as usize] = (((i % (13 as u64)) & (15 as u64)) | (((i + 1) % (13 as u64)) << 4)) as byte;
        i = i + 1;
    }
}

fn bench_run_tokens(tokens: u64, matrix: &f32, x: &f32, out: &f32, q8: &byte, q4: &byte) f32 {
    var checksum: f32 = 0.0f32;
    var t: u64 = 0;
    while t < tokens {
        kernels_dense_matvec_f32(out, matrix, x, 16, 64);
        checksum = checksum + out[(t % 16) as usize];
        checksum = checksum + kernels_q8_0_dot_f32(q8 as &const byte, x as &const f32, 32);
        checksum = checksum + kernels_q4_k_dot_f32(q4 as &const byte, x as &const f32, 64);
        x[(t % 64) as usize] = x[(t % 64) as usize] + 0.000001f32 * checksum;
        t = t + 1;
    }
    return checksum;
}

export fn bench_run_synthetic(prompt_tokens: u64, decode_tokens: u64, out_result: &BenchResult) bool {
    if prompt_tokens == 0 || decode_tokens == 0 || out_result == null {
        return false;
    }
    var matrix: [f32: 1024] = [];
    var x: [f32: 64] = [];
    var out: [f32: 16] = [];
    var q8: [byte: 34] = [];
    var q4: [byte: 144] = [];
    bench_init(&matrix[0], &x[0], &q8[0], &q4[0]);

    const p0: u64 = clock() as u64;
    const prompt_checksum: f32 = bench_run_tokens(prompt_tokens, &matrix[0], &x[0], &out[0], &q8[0], &q4[0]);
    const p1: u64 = clock() as u64;
    const decode_checksum: f32 = bench_run_tokens(decode_tokens, &matrix[0], &x[0], &out[0], &q8[0], &q4[0]);
    const p2: u64 = clock() as u64;

    const prompt_seconds: f32 = bench_elapsed_seconds(p0, p1);
    const decode_seconds: f32 = bench_elapsed_seconds(p1, p2);
    *out_result = BenchResult{
        prompt_tokens: prompt_tokens,
        decode_tokens: decode_tokens,
        prompt_seconds: prompt_seconds,
        decode_seconds: decode_seconds,
        prompt_tokens_per_sec: (prompt_tokens as f32) / prompt_seconds,
        decode_tokens_per_sec: (decode_tokens as f32) / decode_seconds,
        checksum: prompt_checksum + decode_checksum,
    };
    return true;
}

export fn print_benchmark() i32 {
    var result: BenchResult = BenchResult{
        prompt_tokens: 0,
        decode_tokens: 0,
        prompt_seconds: 0.0f32,
        decode_seconds: 0.0f32,
        prompt_tokens_per_sec: 0.0f32,
        decode_tokens_per_sec: 0.0f32,
        checksum: 0.0f32,
    };
    if !bench_run_synthetic(256, 128, &result) {
        _ = printf("ds4-uya: benchmark failed\n");
        return 1;
    }
    _ = printf("ds4-uya synthetic CPU benchmark\n");
    _ = printf("prompt: %llu tokens in %.6f sec, %.2f tokens/s\n", result.prompt_tokens, result.prompt_seconds, result.prompt_tokens_per_sec);
    _ = printf("decode: %llu tokens in %.6f sec, %.2f tokens/s\n", result.decode_tokens, result.decode_seconds, result.decode_tokens_per_sec);
    _ = printf("checksum: %.6f\n", result.checksum);
    return 0;
}
