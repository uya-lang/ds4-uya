const FLASH_MODEL_NEG_INF: f32 = -1000000000000000019884624838656.0f32;
const FLASH_RMS_EPS: f32 = 0.000001f32;
const FLASH_HC_EPS: f32 = 0.000001f32;
const FLASH_EXPERT_WEIGHT_SCALE: f32 = 1.5f32;
const FLASH_SWIGLU_CLAMP: f32 = 10.0f32;
const FLASH_ROPE_FREQ_BASE: f32 = 10000.0f32;
const FLASH_COMPRESS_ROPE_FREQ_BASE: f32 = 160000.0f32;
const FLASH_ROPE_SCALE_FACTOR: f32 = 16.0f32;
const FLASH_ROPE_YARN_BETA_FAST: f32 = 32.0f32;
const FLASH_ROPE_YARN_BETA_SLOW: f32 = 1.0f32;
const FLASH_ROPE_ORIG_CTX: u64 = 65536;
const FLASH_MAX_THREADS: u64 = 16;
const FLASH_DEFAULT_THREADS: u64 = 8;
const FLASH_THREAD_STACK: usize = 262144;

export const FLASH_DS4_N_LAYER: u64 = 43;
export const FLASH_DS4_N_EMBD: u64 = 4096;
export const FLASH_DS4_N_VOCAB: u64 = 129280;
