export const FLASH_DS4_N_HEAD_KV: u64 = 1;
export const FLASH_DS4_N_HEAD_DIM: u64 = 512;
export const FLASH_DS4_N_VALUE_DIM: u64 = 512;
export const FLASH_DS4_N_ROT: u64 = 64;
export const FLASH_DS4_N_OUT_GROUP: u64 = 8;
export const FLASH_DS4_N_LORA_Q: u64 = 1024;
export const FLASH_DS4_N_LORA_O: u64 = 1024;
export const FLASH_DS4_N_EXPERT: u64 = 256;
export const FLASH_DS4_N_EXPERT_USED: u64 = 6;
export const FLASH_DS4_N_EXPERT_SHARED: u64 = 1;
export const FLASH_DS4_N_FF_EXP: u64 = 2048;
export const FLASH_DS4_N_HASH_LAYER: u64 = 3;
export const FLASH_DS4_N_SWA: u64 = 128;
export const FLASH_DS4_N_INDEXER_HEAD: u64 = 64;
export const FLASH_DS4_N_INDEXER_HEAD_DIM: u64 = 128;
export const FLASH_DS4_N_INDEXER_TOP_K: u64 = 512;
export const FLASH_DS4_N_HC: u64 = 4;
export const FLASH_DS4_N_HC_SINKHORN_ITER: u64 = 20;

