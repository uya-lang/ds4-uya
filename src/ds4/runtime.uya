const RUNTIME_DEFAULT_MAX_NEW: u64 = 64;
const RUNTIME_CHAT_MAX_NEW: u64 = 96;

extern "libc" fn memcpy(dest: &void, src: &const void, n: usize) &void;

export struct RuntimeSession {
    info: GgufInfo,
    table: TensorWeightTable,
    vocab: TokenizerVocab,
    config: ModelConfig,
    weights: ModelWeights,
    model: Model,
    state: ModelState,
    tensor_data: & &byte,
    tensor_data_count: u64,
    mmap_base: &byte,
    mmap_size: u64,
    loaded: bool,
}

fn runtime_empty_model() Model {
    var config: ModelConfig = model_config_init(0, 0, 0, 0, 0, 0);
    return Model{ config: config, weights: null };
}

fn runtime_f32_from_bits(bits: u64) f32 {
    var raw: u32 = bits as u32;
    var value: f32 = 0.0f32;
    _ = memcpy(&value as &void, &raw as &const void, 4 as usize);
    return value;
}

export fn runtime_session_init() RuntimeSession {
    return RuntimeSession{
        info: gguf_info_init(),
        table: tensor_weight_table_init(),
        vocab: tokenizer_vocab_init(),
        config: model_config_init(0, 0, 0, 0, 0, 0),
        weights: model_weights_init(),
        model: runtime_empty_model(),
        state: model_state_empty(),
        tensor_data: null,
        tensor_data_count: 0,
        mmap_base: null,
        mmap_size: 0,
        loaded: false,
    };
}

fn runtime_free_tensor_data(session: &RuntimeSession) void {
    if session.mmap_base != null && session.mmap_size != 0 {
        _ = sys_munmap(session.mmap_base as *void, session.mmap_size as usize);
    }
    session.mmap_base = null;
    session.mmap_size = 0;

    if session.tensor_data != null {
        var i: u64 = 0;
        while i < session.tensor_data_count {
            if session.tensor_data[i as usize] != null {
                free(session.tensor_data[i as usize] as &void);
            }
            i = i + 1;
        }
        free(session.tensor_data as &void);
    }
    session.tensor_data = null;
    session.tensor_data_count = 0;
}

export fn runtime_session_deinit(session: &RuntimeSession) void {
    model_state_deinit(&session.state);
    model_weights_deinit(&session.weights);
    tokenizer_vocab_deinit(&session.vocab);
    runtime_free_tensor_data(session);
    tensor_weight_table_deinit(&session.table);
    gguf_info_deinit(&session.info);
    *session = runtime_session_init();
}

fn runtime_load_tensor_data(path: &const byte, session: &RuntimeSession) i32 {
    runtime_free_tensor_data(session);
    if session.table.count == 0 {
        return 3;
    }

    const fd: i32 = sys_open(path as *const byte, O_RDONLY as i32, 0) catch |_| {
        return 2;
    };

    var st: Stat = Stat{
        st_dev: 0, st_ino: 0, st_nlink: 0, st_mode: 0, st_uid: 0, st_gid: 0, _pad0: 0,
        st_rdev: 0, st_size: 0, st_blksize: 0, st_blocks: 0, st_atime: 0, st_atime_nsec: 0,
        st_mtime: 0, st_mtime_nsec: 0, st_ctime: 0, st_ctime_nsec: 0, _unused0: 0,
        _unused1: 0, _unused2: 0,
    };
    if (sys_fstat(fd, &st) catch |_| { _ = sys_close(fd); return 2; }) != 0 || st.st_size <= 0 {
        _ = sys_close(fd);
        return 2;
    }
    const map_size: u64 = st.st_size as u64;
    const raw: *void = sys_mmap(null as *void, map_size as usize, PROT_READ, MAP_PRIVATE, fd, 0) catch |_| {
        _ = sys_close(fd);
        return 2;
    };
    _ = sys_close(fd);
    session.mmap_base = raw as &byte;
    session.mmap_size = map_size;

    var i: u64 = 0;
    while i < session.table.count {
        const view: &TensorView = &session.table.views[i as usize];
        if !tensor_view_data_available(view) {
            runtime_free_tensor_data(session);
            return 3;
        }
        if view.file_offset > map_size || view.byte_size > (map_size - view.file_offset) {
            runtime_free_tensor_data(session);
            return 3;
        }
        const base_addr: usize = @usize_from_ptr(session.mmap_base as &void);
        view.data = @ptr_from_usize(base_addr + (view.file_offset as usize)) as &byte;
        i = i + 1;
    }

    return 0;
}

fn runtime_make_layer_name(out: &byte, cap: usize, layer: u64, suffix: &const byte) bool {
    const rc: i32 = snprintf(out, cap, "blk.%llu.%s\0" as &const byte, layer, suffix);
    return rc > 0 && (rc as usize) < cap;
}

fn runtime_find_layer_tensor(table: &TensorWeightTable, layer: u64, suffix: &const byte) &TensorView {
    var name: [byte: 128] = [];
    if !runtime_make_layer_name(&name[0], 128, layer, suffix) {
        return null;
    }
    return tensor_weight_table_find(table, &name[0] as &const byte);
}

fn runtime_count_layers(table: &TensorWeightTable) u64 {
    var count: u64 = 0;
    while count < table.count {
        if runtime_find_layer_tensor(table, count, "attn_norm.weight\0" as &const byte) == null {
            return count;
        }
        count = count + 1;
    }
    return count;
}

fn runtime_build_config(session: &RuntimeSession) bool {
    if session.table.token_embd == null || session.table.output_norm == null || session.table.output == null {
        return false;
    }
    if session.table.token_embd.n_dims != 2 {
        return false;
    }

    const n_embd: u64 = session.table.token_embd.shape[0];
    const n_vocab: u64 = session.table.token_embd.shape[1];
    var n_layer: u64 = runtime_count_layers(&session.table);
    if session.info.has_block_count {
        n_layer = session.info.block_count;
    }
    if n_layer == 0 {
        return false;
    }

    const gate0: &TensorView = runtime_find_layer_tensor(&session.table, 0, "ffn_gate.weight\0" as &const byte);
    if gate0 == null || gate0.n_dims != 2 || gate0.shape[0] != n_embd {
        return false;
    }
    const n_ff: u64 = gate0.shape[1];

    var n_ctx: u64 = 2048;
    if session.info.has_context_length {
        n_ctx = session.info.context_length;
    }
    var n_head: u64 = 1;
    if session.info.has_head_count {
        n_head = session.info.head_count;
    }
    var n_head_kv: u64 = n_head;
    if session.info.has_head_count_kv {
        n_head_kv = session.info.head_count_kv;
    }
    if n_head == 0 || n_head_kv == 0 || (n_head % n_head_kv) != 0 {
        return false;
    }
    if (n_embd % n_head) != 0 {
        return false;
    }

    var config: ModelConfig = model_config_init(n_vocab, n_embd, n_layer, n_ctx, n_head, n_ff);
    config.n_head_kv = n_head_kv;
    config.head_dim = n_embd / n_head;
    config.key_dim = config.head_dim;
    if session.info.has_key_length {
        config.key_dim = session.info.key_length;
    }
    config.value_dim = config.head_dim;
    if session.info.has_value_length {
        config.value_dim = session.info.value_length;
    }
    if session.info.has_embedding_length && session.info.embedding_length != n_embd {
        return false;
    }
    if session.info.has_rope_dimension_count {
        config.rope_dim = session.info.rope_dimension_count;
    } else if (config.head_dim % (2 as u64)) == 0 {
        config.rope_dim = config.head_dim;
    } else {
        config.rope_dim = 0;
    }
    if session.info.has_rope_freq_base {
        config.rope_theta = runtime_f32_from_bits(session.info.rope_freq_base_bits);
    }
    if session.info.has_rms_eps {
        config.rms_eps = runtime_f32_from_bits(session.info.rms_eps_bits);
    }

    if !model_config_validate(&config) {
        return false;
    }
    session.config = config;
    return true;
}

fn runtime_print_load_error(path: &const byte, rc: i32) void {
    if rc == 2 {
        _ = printf("ds4-uya: cannot open model or allocate runtime memory: %s\n", path);
    } else if rc == 3 {
        _ = printf("ds4-uya: GGUF tensor data is truncated or unreadable: %s\n", path);
    } else if rc == 6 {
        _ = printf("ds4-uya: GGUF tensor data is truncated; run `ds4-uya audit %s` for schema-only diagnostics\n", path);
    } else if rc == 7 {
        _ = printf("ds4-uya: GGUF is missing required root tensors token_embd/output_norm/output\n");
    } else if rc == 8 {
        _ = printf("ds4-uya: GGUF is missing tokenizer.ggml.tokens or tokenizer.ggml.merges metadata\n");
    } else if rc == 9 {
        _ = printf("ds4-uya: unsupported model layout for current CPU forward path\n");
        _ = printf("ds4-uya: supported now: dense decoder tensors named blk.N.*, dense GQA/MQA with key/value dims equal to head_dim, F32/F16/Q8_0/Q2_K/Q4_K/IQ2_* matrices\n");
        _ = printf("ds4-uya: run `ds4-uya audit <model.gguf>` for DS4 Flash/MoE/compressor/indexer diagnostics\n");
    } else {
        _ = printf("ds4-uya: failed to load GGUF-backed runtime, rc=%d\n", rc);
    }
}

fn runtime_sample_equals(s: &GgufString, literal: &const byte) bool {
    const n: usize = strlen(literal as *const byte);
    if s.len != n as u64 || s.shown != n {
        return false;
    }
    var i: usize = 0;
    while i < n {
        if s.data[i] != literal[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn runtime_sample_contains(s: &GgufString, needle: &const byte) bool {
    const n: usize = strlen(needle as *const byte);
    if n == 0 {
        return true;
    }
    if s.shown < n {
        return false;
    }
    var i: usize = 0;
    while i + n <= s.shown {
        var j: usize = 0;
        var ok: bool = true;
        while j < n {
            if s.data[i + j] != needle[j] {
                ok = false;
                break;
            }
            j = j + 1;
        }
        if ok {
            return true;
        }
        i = i + 1;
    }
    return false;
}

export fn print_runtime_audit(path: &const byte) i32 {
    var info: GgufInfo = gguf_info_init();
    const rc: i32 = load_gguf(path, &info);
    if rc != 0 && rc != 6 {
        runtime_print_load_error(path, rc);
        gguf_info_deinit(&info);
        return rc;
    }

    _ = printf("ds4-uya audit: %s\n", path);
    if rc == 6 {
        _ = printf("warning: tensor data is truncated; schema/directory audit only. file_size=%llu required_end=%llu\n", info.file_size, info.required_end);
    }
    if info.general_name.len > 0 {
        _ = printf("model: %s\n", &info.general_name.data[0]);
    }
    if info.general_architecture.len > 0 {
        _ = printf("arch: %s\n", &info.general_architecture.data[0]);
    }
    _ = printf("counts: metadata=%llu/%llu tensors=%llu/%llu alignment=%llu tensor_data_start=%llu\n",
        info.loaded_metadata_count, info.metadata_count, info.loaded_tensor_count, info.tensor_count, info.alignment, info.tensor_data_start);
    _ = printf("params:");
    if info.has_block_count { _ = printf(" layers=%llu", info.block_count); }
    if info.has_context_length { _ = printf(" ctx=%llu", info.context_length); }
    if info.has_embedding_length { _ = printf(" embd=%llu", info.embedding_length); }
    if info.has_head_count { _ = printf(" heads=%llu", info.head_count); }
    if info.has_head_count_kv { _ = printf(" kv_heads=%llu", info.head_count_kv); }
    if info.has_key_length { _ = printf(" key_len=%llu", info.key_length); }
    if info.has_value_length { _ = printf(" value_len=%llu", info.value_length); }
    if info.has_expert_count { _ = printf(" experts=%llu", info.expert_count); }
    if info.has_expert_used_count { _ = printf(" experts_used=%llu", info.expert_used_count); }
    if info.has_expert_feed_forward_length { _ = printf(" expert_ff=%llu", info.expert_feed_forward_length); }
    if info.has_expert_shared_count { _ = printf(" shared_experts=%llu", info.expert_shared_count); }
    if info.has_file_type { _ = printf(" file_type=%llu", info.file_type); }
    _ = printf("\n");

    _ = printf("flash-metadata:");
    if info.has_rope_dimension_count { _ = printf(" rope_dim=%llu", info.rope_dimension_count); }
    if info.has_rope_freq_base { _ = printf(" rope_freq_base_bits=%llu", info.rope_freq_base_bits); }
    if info.has_rope_scaling_factor { _ = printf(" rope_scale_bits=%llu", info.rope_scaling_factor_bits); }
    if info.has_rms_eps { _ = printf(" rms_eps_bits=%llu", info.rms_eps_bits); }
    if info.has_q_lora_rank { _ = printf(" q_lora=%llu", info.q_lora_rank); }
    if info.has_output_lora_rank { _ = printf(" out_lora=%llu", info.output_lora_rank); }
    if info.has_output_group_count { _ = printf(" out_groups=%llu", info.output_group_count); }
    if info.has_expert_gating_func { _ = printf(" expert_gate_func=%llu", info.expert_gating_func); }
    if info.has_attention_sliding_window { _ = printf(" sliding_window=%llu", info.attention_sliding_window); }
    if info.has_indexer_head_count { _ = printf(" indexer_heads=%llu", info.indexer_head_count); }
    if info.has_indexer_key_length { _ = printf(" indexer_key_len=%llu", info.indexer_key_length); }
    if info.has_indexer_top_k { _ = printf(" indexer_top_k=%llu", info.indexer_top_k); }
    if info.has_hyper_connection_count { _ = printf(" hc_count=%llu", info.hyper_connection_count); }
    _ = printf("\n");

    var dense_roots: u64 = 0;
    var dense_attn: u64 = 0;
    var moe_experts: u64 = 0;
    var shared_experts: u64 = 0;
    var router_tensors: u64 = 0;
    var compressor_tensors: u64 = 0;
    var indexer_tensors: u64 = 0;
    var hc_tensors: u64 = 0;
    var lora_split_tensors: u64 = 0;
    var q2_k_tensors: u64 = 0;
    var iq2_tensors: u64 = 0;
    var iq2_xxs_tensors: u64 = 0;
    var iq2_xs_tensors: u64 = 0;
    var iq2_s_tensors: u64 = 0;
    var q4_k_tensors: u64 = 0;
    var q8_0_tensors: u64 = 0;
    var f16_tensors: u64 = 0;
    var f32_tensors: u64 = 0;
    var i32_tensors: u64 = 0;

    var i: u64 = 0;
    while i < info.loaded_tensor_count {
        const tensor: &GgufTensorInfo = &info.tensors[i as usize];
        if runtime_sample_equals(&tensor.name, "token_embd.weight\0" as &const byte) ||
            runtime_sample_equals(&tensor.name, "output_norm.weight\0" as &const byte) ||
            runtime_sample_equals(&tensor.name, "output.weight\0" as &const byte) {
            dense_roots = dense_roots + 1;
        }
        if runtime_sample_contains(&tensor.name, ".attn_q.weight\0" as &const byte) ||
            runtime_sample_contains(&tensor.name, ".attn_k.weight\0" as &const byte) ||
            runtime_sample_contains(&tensor.name, ".attn_v.weight\0" as &const byte) ||
            runtime_sample_contains(&tensor.name, ".attn_output.weight\0" as &const byte) {
            dense_attn = dense_attn + 1;
        }
        if runtime_sample_contains(&tensor.name, "_exps.weight\0" as &const byte) {
            moe_experts = moe_experts + 1;
        }
        if runtime_sample_contains(&tensor.name, "_shexp.weight\0" as &const byte) {
            shared_experts = shared_experts + 1;
        }
        if runtime_sample_contains(&tensor.name, "ffn_gate_\0" as &const byte) ||
            runtime_sample_contains(&tensor.name, "exp_probs\0" as &const byte) {
            router_tensors = router_tensors + 1;
        }
        if runtime_sample_contains(&tensor.name, "compressor\0" as &const byte) {
            compressor_tensors = compressor_tensors + 1;
        }
        if runtime_sample_contains(&tensor.name, "indexer\0" as &const byte) {
            indexer_tensors = indexer_tensors + 1;
        }
        if runtime_sample_contains(&tensor.name, "_hc_\0" as &const byte) ||
            runtime_sample_contains(&tensor.name, ".hc_\0" as &const byte) {
            hc_tensors = hc_tensors + 1;
        }
        if runtime_sample_contains(&tensor.name, "attn_q_a.weight\0" as &const byte) ||
            runtime_sample_contains(&tensor.name, "attn_q_b.weight\0" as &const byte) ||
            runtime_sample_contains(&tensor.name, "attn_kv_a_norm.weight\0" as &const byte) ||
            runtime_sample_contains(&tensor.name, "attn_kv.weight\0" as &const byte) ||
            runtime_sample_contains(&tensor.name, "attn_output_a.weight\0" as &const byte) ||
            runtime_sample_contains(&tensor.name, "attn_output_b.weight\0" as &const byte) {
            lora_split_tensors = lora_split_tensors + 1;
        }

        if tensor.ggml_type == GGML_TYPE_Q2_K {
            q2_k_tensors = q2_k_tensors + 1;
        } else if tensor.ggml_type == GGML_TYPE_IQ2_XXS {
            iq2_tensors = iq2_tensors + 1;
            iq2_xxs_tensors = iq2_xxs_tensors + 1;
        } else if tensor.ggml_type == GGML_TYPE_IQ2_XS {
            iq2_tensors = iq2_tensors + 1;
            iq2_xs_tensors = iq2_xs_tensors + 1;
        } else if tensor.ggml_type == GGML_TYPE_IQ2_S {
            iq2_tensors = iq2_tensors + 1;
            iq2_s_tensors = iq2_s_tensors + 1;
        } else if tensor.ggml_type == GGML_TYPE_Q4_K {
            q4_k_tensors = q4_k_tensors + 1;
        } else if tensor.ggml_type == GGML_TYPE_Q8_0 {
            q8_0_tensors = q8_0_tensors + 1;
        } else if tensor.ggml_type == GGML_TYPE_F16 {
            f16_tensors = f16_tensors + 1;
        } else if tensor.ggml_type == GGML_TYPE_F32 {
            f32_tensors = f32_tensors + 1;
        } else if tensor.ggml_type == GGML_TYPE_I32 {
            i32_tensors = i32_tensors + 1;
        }
        i = i + 1;
    }

    _ = printf("layout: dense_roots=%llu dense_attn=%llu moe_experts=%llu shared_experts=%llu router=%llu compressor=%llu indexer=%llu hc=%llu split_lora=%llu\n",
        dense_roots, dense_attn, moe_experts, shared_experts, router_tensors, compressor_tensors, indexer_tensors, hc_tensors, lora_split_tensors);
    _ = printf("dtypes: f32=%llu f16=%llu i32=%llu q8_0=%llu q4_k=%llu q2_k=%llu iq2=%llu\n",
        f32_tensors, f16_tensors, i32_tensors, q8_0_tensors, q4_k_tensors, q2_k_tensors, iq2_tensors);
    if iq2_tensors != 0 {
        _ = printf("iq2-breakdown: iq2_xxs=%llu iq2_xs=%llu iq2_s=%llu\n",
            iq2_xxs_tensors, iq2_xs_tensors, iq2_s_tensors);
    }

    if info.has_head_count && info.has_head_count_kv && info.head_count != info.head_count_kv {
        _ = printf("diagnostic: GQA/MQA metadata detected; dense GQA is supported when key_len/value_len equal head_dim\n");
    }
    if info.has_key_length && info.has_head_count && info.has_embedding_length && info.head_count != 0 {
        const head_dim: u64 = info.embedding_length / info.head_count;
        if info.key_length != head_dim || (info.has_value_length && info.value_length != head_dim) {
            _ = printf("diagnostic: Flash key/value dims require compressor/LORA branch (head_dim=%llu key_len=%llu value_len=%llu)\n",
                head_dim, info.key_length, info.value_length);
        }
    }
    if moe_experts != 0 || router_tensors != 0 || shared_experts != 0 {
        _ = printf("diagnostic: Flash MoE tensors detected; router/shared/expert forward is not wired into generation yet\n");
    }
    if compressor_tensors != 0 || indexer_tensors != 0 || hc_tensors != 0 || lora_split_tensors != 0 {
        _ = printf("diagnostic: Flash compressor/indexer/HC/split-LORA tensors detected; current forward reports unsupported instead of fake generation\n");
    }
    if iq2_tensors != 0 {
        _ = printf("diagnostic: IQ2 tensors detected; IQ2_XXS/IQ2_XS/IQ2_S reference kernels are wired into dense matvec\n");
    }

    gguf_info_deinit(&info);
    return 0;
}

export fn runtime_session_load_gguf(path: &const byte, session: &RuntimeSession) i32 {
    runtime_session_deinit(session);

    const load_rc: i32 = load_gguf(path, &session.info);
    if load_rc != 0 {
        return load_rc;
    }

    const table_rc: i32 = tensor_weight_table_load_from_gguf(path, &session.table);
    if table_rc != 0 {
        runtime_session_deinit(session);
        return table_rc;
    }

    if !runtime_build_config(session) {
        runtime_session_deinit(session);
        return 9;
    }

    const vocab_rc: i32 = tokenizer_vocab_load_from_gguf(path, &session.vocab);
    if vocab_rc != 0 {
        runtime_session_deinit(session);
        return vocab_rc;
    }

    const data_rc: i32 = runtime_load_tensor_data(path, session);
    if data_rc != 0 {
        runtime_session_deinit(session);
        return data_rc;
    }

    if !model_weights_bind_from_table(&session.config, &session.table, &session.weights) {
        runtime_session_deinit(session);
        return 9;
    }
    session.model = model_init(&session.config, &session.weights);
    if !model_state_init(&session.state, &session.config) {
        runtime_session_deinit(session);
        return 2;
    }
    session.loaded = true;
    return 0;
}

fn runtime_clear_byte_buffer(out: &TokenizerByteBuffer) void {
    out.len = 0;
    if out.data != null {
        out.data[0] = 0;
    }
}

fn runtime_decode_generated(session: &RuntimeSession, tokens: &i32, start: u64, generated: u64, out: &TokenizerByteBuffer) bool {
    var gen_tokens: TokenizerTokenVec = tokenizer_token_vec_init();
    var i: u64 = 0;
    while i < generated {
        const token: i32 = tokens[(start + i) as usize];
        if session.vocab.eos_id >= 0 && token == session.vocab.eos_id {
            break;
        }
        if !tokenizer_token_vec_push(&gen_tokens, token) {
            tokenizer_token_vec_deinit(&gen_tokens);
            return false;
        }
        i = i + 1;
    }
    const rc: i32 = tokenizer_decode_tokens(&session.vocab, &gen_tokens, out);
    tokenizer_token_vec_deinit(&gen_tokens);
    return rc == 0;
}

export fn runtime_session_generate_to_buffer(
    session: &RuntimeSession,
    prompt: &const byte,
    max_new_tokens: u64,
    out: &TokenizerByteBuffer,
) i32 {
    runtime_clear_byte_buffer(out);
    if !session.loaded || max_new_tokens == 0 {
        return 10;
    }

    var prompt_tokens: TokenizerTokenVec = tokenizer_token_vec_init();
    const encode_rc: i32 = tokenizer_encode_text(&session.vocab, prompt, &prompt_tokens, true, session.vocab.add_bos, false);
    if encode_rc != 0 || prompt_tokens.len == 0 {
        tokenizer_token_vec_deinit(&prompt_tokens);
        return 10;
    }

    const token_cap: u64 = prompt_tokens.len + max_new_tokens;
    if token_cap > session.config.n_ctx {
        tokenizer_token_vec_deinit(&prompt_tokens);
        return 10;
    }

    const token_bytes: usize = (token_cap as usize) * (@size_of(i32) as usize);
    const tokens: &i32 = malloc(token_bytes) as &i32;
    const logits: &f32 = malloc((session.config.n_vocab as usize) * (@size_of(f32) as usize)) as &f32;
    if tokens == null || logits == null {
        if tokens != null { free(tokens as &void); }
        if logits != null { free(logits as &void); }
        tokenizer_token_vec_deinit(&prompt_tokens);
        return 2;
    }

    var i: u64 = 0;
    while i < prompt_tokens.len {
        tokens[i as usize] = prompt_tokens.data[i as usize];
        i = i + 1;
    }

    var gen_config: GenerationConfig = generation_config_greedy(max_new_tokens);
    if session.vocab.eos_id >= 0 {
        gen_config.eos_token = session.vocab.eos_id;
        gen_config.stop_on_eos = true;
    }
    var sampler_state: SamplerState = sampler_state_init(1);
    var generated: u64 = 0;
    const ok: bool = generation_generate(&session.model, &session.state, tokens, prompt_tokens.len, token_cap, logits, &gen_config, &sampler_state, &generated);
    var rc: i32 = 0;
    if !ok || !runtime_decode_generated(session, tokens, prompt_tokens.len, generated, out) {
        rc = 10;
    }

    free(tokens as &void);
    free(logits as &void);
    tokenizer_token_vec_deinit(&prompt_tokens);
    return rc;
}

export fn runtime_generate_to_buffer(path: &const byte, prompt: &const byte, max_new_tokens: u64, out: &TokenizerByteBuffer) i32 {
    var session: RuntimeSession = runtime_session_init();
    const load_rc: i32 = runtime_session_load_gguf(path, &session);
    if load_rc != 0 {
        runtime_session_deinit(&session);
        return load_rc;
    }
    const rc: i32 = runtime_session_generate_to_buffer(&session, prompt, max_new_tokens, out);
    runtime_session_deinit(&session);
    return rc;
}

export fn print_runtime_generate(path: &const byte, prompt: &const byte) i32 {
    var out: TokenizerByteBuffer = tokenizer_byte_buffer_init();
    const rc: i32 = runtime_generate_to_buffer(path, prompt, RUNTIME_DEFAULT_MAX_NEW, &out);
    if rc == 0 {
        if out.data != null {
            _ = printf("%s", &out.data[0]);
        }
        _ = printf("\n");
    } else {
        runtime_print_load_error(path, rc);
    }
    tokenizer_byte_buffer_deinit(&out);
    return rc;
}

fn runtime_read_line(buf: &byte, cap: usize) i64 {
    if cap == 0 {
        return -1;
    }
    var pos: usize = 0;
    while pos + 1 < cap {
        const got: i64 = read(0, &buf[pos], 1 as usize);
        if got < 0 {
            return -1;
        }
        if got == 0 {
            if pos == 0 {
                return 0;
            }
            break;
        }
        if buf[pos] == (10 as byte) {
            break;
        }
        pos = pos + 1;
    }
    if pos > 0 && buf[pos - 1] == (13 as byte) {
        pos = pos - 1;
    }
    buf[pos] = 0;
    return pos as i64;
}

export fn print_runtime_chat(path: &const byte) i32 {
    var session: RuntimeSession = runtime_session_init();
    const load_rc: i32 = runtime_session_load_gguf(path, &session);
    if load_rc != 0 {
        runtime_print_load_error(path, load_rc);
        runtime_session_deinit(&session);
        return load_rc;
    }

    _ = printf("ds4-uya chat ready. Type /quit to exit.\n");
    var line: [byte: 4096] = [];
    var out: TokenizerByteBuffer = tokenizer_byte_buffer_init();
    while true {
        _ = printf("> ");
        _ = fflush(stdout);
        const n: i64 = runtime_read_line(&line[0], 4096);
        if n <= 0 {
            break;
        }
        if strcmp(&line[0] as *const byte, "/quit\0" as *const byte) == 0 ||
            strcmp(&line[0] as *const byte, "/exit\0" as *const byte) == 0 {
            break;
        }
        const rc: i32 = runtime_session_generate_to_buffer(&session, &line[0] as &const byte, RUNTIME_CHAT_MAX_NEW, &out);
        if rc != 0 {
            runtime_print_load_error(path, rc);
            tokenizer_byte_buffer_deinit(&out);
            runtime_session_deinit(&session);
            return rc;
        }
        if out.data != null {
            _ = printf("%s", &out.data[0]);
        }
        _ = printf("\n");
    }

    tokenizer_byte_buffer_deinit(&out);
    runtime_session_deinit(&session);
    return 0;
}
